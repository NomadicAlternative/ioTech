# .env.example - placeholders para una plataforma IoT SaaS basada en Node.js y MQTT
# No incluir valores reales. Reemplaza los placeholders en tu archivo .env local.

# Puerto en el que corre la aplicación
PORT=3000
NODE_ENV=development
# NODE_ENV: define el modo de ejecución de la aplicación.
# Usa "development" para desarrollo local, "production" en producción y
# "test" para entornos de prueba. Afecta logging, optimizaciones y
# comportamientos específicos del entorno.

# MQTT broker
MQTT_BROKER_URL=tcp://broker.example.com:1883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# Seguridad
JWT_SECRET=your_jwt_secret_here

# Base de datos (ejemplo PostgreSQL). Ajusta el esquema según tu DB (mongodb, mysql, etc.)
DATABASE_URL=postgresql://db_user:db_password@localhost:5432/db_name
