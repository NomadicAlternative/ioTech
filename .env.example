# .env.example - placeholders para una plataforma IoT SaaS basada en Node.js y MQTT
# No incluir valores reales. Reemplaza los placeholders en tu archivo .env local.

# Puerto en el que corre la aplicación
PORT=3000
NODE_ENV=development
# NODE_ENV: define el modo de ejecución de la aplicación.
# Usa "development" para desarrollo local, "production" en producción y
# "test" para entornos de prueba. Afecta logging, optimizaciones y
# comportamientos específicos del entorno.

# MQTT broker
MQTT_BROKER_URL=mqtts://broker.example.com:8883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password
# Optional: separate credentials for devices (avoids HiveMQ free-tier 1-connection limit)
# If not set, devices use MQTT_USERNAME/MQTT_PASSWORD
# MQTT_DEVICE_USERNAME=your_device_mqtt_username
# MQTT_DEVICE_PASSWORD=your_device_mqtt_password

# Base de datos PostgreSQL + TimescaleDB
DATABASE_URL=postgresql://user:password@localhost:5432/iotech_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iotech_dev
DB_USER=iotech_app
DB_PASSWORD=secret
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT — autenticación de usuarios
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m

# JWT — refresh tokens
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# Frontend (Vite) — API base URL for axios and Socket.IO
# Set at build time via CI/CD (see .github/workflows/deploy.yml).
# When unset, falls back to http://localhost:3000 for local development.
# VITE_API_URL=https://beepdash.com

# Auth rate limiting (express-rate-limit v7, in-memory)
AUTH_RATE_LIMIT_ENABLED=true
# AUTH_RATE_LIMIT_LOGIN_MAX=20
# AUTH_RATE_LIMIT_LOGIN_WINDOW_MS=900000
# AUTH_RATE_LIMIT_REGISTER_MAX=10
# AUTH_RATE_LIMIT_REGISTER_WINDOW_MS=3600000
# AUTH_RATE_LIMIT_REFRESH_MAX=30
# AUTH_RATE_LIMIT_REFRESH_WINDOW_MS=900000
# AUTH_RATE_LIMIT_LOGOUT_MAX=60
# AUTH_RATE_LIMIT_LOGOUT_WINDOW_MS=900000
