{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/proxy/:path*" },
    { "source": "/((?!api|_next|_vercel|.*\\..*).*)", "destination": "/index.html" }
  ]
}
